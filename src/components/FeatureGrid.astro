---
const features = [
  {
    title: "YouTube & YouTube Music",
    body: "Search YouTube and YouTube Music from their own screens in Station. Preview results and add tracks to your library when you want them—you're in control of what gets saved.",
  },
  {
    title: "Library & metadata",
    body: "Edit tracks, artwork, and playlists with a polished, app-like workflow. Everything you change stays on your storage.",
  },
  {
    title: "Play everywhere",
    body: "Stream from your main Station to desktop and mobile. Queue and playback stay in sync across sessions.",
  },
  {
    title: "Browse your library",
    body: "Album grids, artist pages, and playlists built for large collections. Finding music in your library is its own search and browse flow—separate from searching YouTube or YouTube Music.",
  },
  {
    title: "Flexible storage",
    body: "Store your library on local disk, a NAS, or object storage, including common S3-compatible backends—use what fits your setup.",
  },
  {
    title: "Reachable anywhere",
    body: "Run at home on your network, or reach your Station safely through Tailscale or a reverse proxy so your music is available when you're away.",
  },
] as const;
---

<section
  class="mx-auto max-w-6xl px-4 py-20 sm:px-6 lg:px-8"
  aria-labelledby="features-heading"
>
  <div data-reveal class="max-w-2xl">
    <h2
      id="features-heading"
      class="font-display text-3xl font-semibold tracking-tight text-main sm:text-4xl"
    >
      Everything you expect from a modern player
    </h2>
    <p class="mt-4 text-lg text-dim">
      Self-hosted, private, and as polished as the apps you grew up streaming on—with a
      polished experience for the music you already own, plus dedicated flows for exploring
      YouTube and YouTube Music and for searching your own library.
    </p>
  </div>

  <ul class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3" role="list">
    {
      features.map((f, i) => (
        <li data-reveal>
          <article class="group relative h-full overflow-hidden rounded-2xl border border-[var(--glass-border)] bg-card/90 p-6 shadow-card backdrop-blur-md transition hover:border-accent/35">
            <div
              class="pointer-events-none absolute -right-8 -top-8 h-32 w-32 rounded-full bg-accent/10 opacity-0 blur-2xl transition group-hover:opacity-100"
              aria-hidden="true"
            />
            <div class="relative">
              <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-xl bg-surface ring-1 ring-[var(--glass-border)]">
                <span
                  class="flex h-6 w-6 items-center justify-center font-display text-sm font-bold text-accent"
                  aria-hidden="true"
                >
                  {i + 1}
                </span>
              </div>
              <h3 class="font-display text-lg font-semibold text-main">
                {f.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-dim">{f.body}</p>
            </div>
          </article>
        </li>
      ))
    }
  </ul>
</section>
