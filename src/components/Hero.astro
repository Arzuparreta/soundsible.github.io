---
import { REPO_URL, DOCS_INSTALL_URL } from "../constants";
---

<section
  class="relative mx-auto flex max-w-6xl flex-col items-center px-4 pb-16 pt-12 text-center sm:px-6 sm:pb-24 sm:pt-20 lg:px-8"
  aria-labelledby="hero-heading"
>
  <div data-reveal class="mb-8 flex items-center gap-3 sm:mb-10">
    <img
      src="/logo-app.png"
      alt=""
      width="56"
      height="56"
      class="h-12 w-12 shrink-0 rounded-xl shadow-glow sm:h-14 sm:w-14"
      fetchpriority="high"
    />
    <span class="font-display text-xl font-semibold tracking-tight text-main sm:text-2xl"
      >Soundsible</span
    >
  </div>

  <h1
    id="hero-heading"
    data-reveal
    class="font-display text-balance text-4xl font-semibold leading-tight tracking-tight text-main sm:text-5xl lg:text-6xl"
  >
    Your music.<br class="hidden sm:block" />
    <span class="bg-gradient-to-r from-accent via-[#ff9a4a] to-secondary bg-clip-text text-transparent"
      >Streaming-grade experience.</span
    >
  </h1>

  <p
    data-reveal
    class="mt-6 max-w-2xl text-balance text-lg text-dim sm:text-xl"
  >
    Self-host a full-featured music environment: search, library, playback, and
    sync across devices—built for the collection you actually own.
  </p>

  <div
    data-reveal
    class="mt-10 flex flex-col items-stretch gap-3 sm:flex-row sm:justify-center"
  >
    <a
      href={REPO_URL}
      class="inline-flex items-center justify-center gap-2 rounded-full bg-accent px-8 py-3.5 text-base font-semibold text-white shadow-card transition hover:brightness-110 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path
          d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
        ></path>
      </svg>
      Get the app on GitHub
    </a>
    <a
      href={DOCS_INSTALL_URL}
      class="inline-flex items-center justify-center rounded-full border border-[var(--glass-border)] bg-surface px-8 py-3.5 text-base font-semibold text-main backdrop-blur-md transition hover:border-accent/40 hover:bg-card focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-secondary"
    >
      Installation guide
    </a>
  </div>

  <p class="mt-8 text-sm text-dim">
    Python 3.10+ · FFmpeg · Open source (MIT)
  </p>
</section>
