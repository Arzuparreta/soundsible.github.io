---
import { publicAsset } from "../public-asset";

const desktop = {
  src: publicAsset("/screenshots/desktop-player-dark.png"),
  alt: "Soundsible desktop player with dark theme showing library and playback",
  caption: "Station — desktop",
};
const mobile = [
  {
    src: publicAsset("/screenshots/mobile-yt-search.PNG"),
    alt: "YouTube and YouTube Music search on Soundsible mobile",
    cap: "YouTube & YouTube Music",
  },
  {
    src: publicAsset("/screenshots/mobile-now-playing.PNG"),
    alt: "Now playing screen on mobile",
    cap: "Now playing",
  },
  {
    src: publicAsset("/screenshots/mobile-songs-library.PNG"),
    alt: "Songs library on mobile",
    cap: "Library",
  },
] as const;

const mobileStripCaption = "Station — mobile";
---

<section
  class="mx-auto max-w-6xl px-4 py-20 sm:px-6 lg:px-8"
  aria-labelledby="showcase-heading"
>
  <div data-reveal class="text-center">
    <h2
      id="showcase-heading"
      class="font-display text-3xl font-semibold tracking-tight text-main sm:text-4xl"
    >
      Built for daily listening
    </h2>
    <p class="mx-auto mt-4 max-w-2xl text-lg text-dim">
      The same interface scales from your desk to your phone: add tracks from YouTube and YouTube Music on their own screens, then browse and search your library separately—in dark-first layouts built for big collections.
    </p>
  </div>

  <div data-reveal class="mt-14 space-y-8">
    <figure
      class="overflow-hidden rounded-2xl border border-[var(--glass-border)] bg-card/60 shadow-card backdrop-blur-sm"
    >
      <img
        src={desktop.src}
        alt={desktop.alt}
        width="1200"
        height="675"
        class="h-auto w-full object-cover object-top"
        loading="lazy"
        decoding="async"
      />
      <figcaption class="border-t border-[var(--glass-border)] px-4 py-3 text-center text-sm text-dim">
        {desktop.caption}
      </figcaption>
    </figure>

    <figure
      class="overflow-hidden rounded-2xl border border-[var(--glass-border)] bg-card/60 shadow-card backdrop-blur-sm"
    >
      <div
        class="flex flex-row items-start justify-center gap-3 px-3 py-4 sm:gap-5 sm:px-5 sm:py-6 md:gap-6 md:px-6 md:py-7"
        role="group"
        aria-label="Mobile app screenshots"
      >
        {
          mobile.map((m) => (
            <div class="flex min-w-0 flex-1 flex-col gap-2 sm:gap-2.5">
              <div class="overflow-hidden rounded-2xl border border-[var(--glass-border)] bg-card/50">
                <img
                  src={m.src}
                  alt={m.alt}
                  width="390"
                  height="844"
                  class="h-auto w-full object-cover object-top"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <p class="px-0.5 text-center text-[0.65rem] leading-snug text-dim sm:text-xs sm:text-sm">
                {m.cap}
              </p>
            </div>
          ))
        }
      </div>
      <figcaption class="border-t border-[var(--glass-border)] px-4 py-3 text-center text-sm text-dim">
        {mobileStripCaption}
      </figcaption>
    </figure>
  </div>
</section>
