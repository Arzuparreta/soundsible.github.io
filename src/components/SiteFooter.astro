---
import { REPO_URL } from "../constants";
const year = new Date().getFullYear();
---

<footer
  class="border-t border-[var(--glass-border)] bg-[#08080a]/90 py-12 backdrop-blur-md"
  data-reveal
>
  <div
    class="mx-auto flex max-w-6xl flex-col items-center gap-6 px-4 text-center sm:flex-row sm:justify-between sm:px-6 sm:text-left lg:px-8"
  >
    <div class="flex items-center gap-3">
      <img src="/logo-app.png" alt="" width="40" height="40" class="rounded-lg" />
      <div>
        <div class="font-display font-semibold text-main">Soundsible</div>
        <div class="text-sm text-dim">Self-hosted music environment</div>
      </div>
    </div>
    <nav class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm" aria-label="Footer">
      <a href={REPO_URL} class="text-dim transition hover:text-main">GitHub</a>
      <a
        href={`${REPO_URL}/blob/main/README.md`}
        class="text-dim transition hover:text-main">README</a
      >
      <a
        href={`${REPO_URL}/blob/main/LICENSE`}
        class="text-dim transition hover:text-main">MIT License</a
      >
    </nav>
  </div>
  <p class="mt-8 text-center text-xs text-dim">
    © {year} Soundsible contributors
  </p>
</footer>
