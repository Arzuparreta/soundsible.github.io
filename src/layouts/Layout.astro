---
import "@fontsource-variable/outfit/wght.css";
import "@fontsource-variable/dm-sans/wght.css";
import "../styles/global.css";
import { publicAsset } from "../public-asset";

interface Props {
  title: string;
  description: string;
  /** Absolute URL; default = og-image.png under the deployed base path */
  ogImage?: string;
}

const { title, description, ogImage: ogImageProp } = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage =
  ogImageProp ??
  new URL(publicAsset("og-image.png"), Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0d0d0f" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href={publicAsset("/favicon.png")} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>
  </head>
  <body class="relative overflow-x-hidden bg-glow-orange bg-glow-blue">
    <div
      class="pointer-events-none fixed inset-0 z-0 bg-[length:48px_48px] bg-grid-fade opacity-70"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none fixed inset-0 z-0 bg-gradient-to-b from-[#0d0d0f]/80 via-transparent to-[#0a0a0c]"
      aria-hidden="true"
    >
    </div>
    <div class="relative z-10">
      <slot />
    </div>

    <script>
      import "../scripts/reveal-entry.ts";
    </script>
  </body>
</html>
